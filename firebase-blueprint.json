{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Addon": {
      "title": "Addon",
      "description": "Stores information about a generated addon.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "prompt": { "type": "string" },
        "files": { "type": "object" },
        "likes": { "type": "number" },
        "isPublic": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "name", "files"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/addons/{addonId}": {
      "schema": "Addon",
      "description": "Addons created by users."
    }
  }
}
